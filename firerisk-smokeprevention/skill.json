{
    "id": "firerisk_smokeprevention",
    "name": "Fire Risk - Smoke Prevention",
    "description": "Reviews supplied site files for outdoor smoking facilities and non-smoking signage, then returns structured field results.",
    "modelClass": "Standard",
    "mcpServers": [],
    "inputSchema": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "description": "One or more files to review. Each file is represented as a JSON object containing the original filename, MIME type, and base64-encoded file bytes.",
          "items": {
            "type": "object",
            "description": "A file supplied to the skill.",
            "properties": {
              "name": {
                "type": "string",
                "description": "Original filename, for example site-photo.jpg, report.pdf, or data.json."
              },
              "mimeType": {
                "type": "string",
                "description": "File MIME type, for example image/jpeg, image/png, application/pdf, application/json, text/plain, or application/vnd.openxmlformats-officedocument.wordprocessingml.document."
              },
              "data": {
                "type": "string",
                "description": "Base64-encoded file bytes. Do not include a data URL prefix such as data:image/jpeg;base64,."
              }
            },
            "required": ["name", "mimeType", "data"],
            "additionalProperties": false
          }
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "fields": {
            "type": "array",
            "description": "Structured result fields returned by the skill.",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "name": { "const": "smokeFacilities" },
                    "description": { "const": "Are outdoor smoking facilities provided?" },
                    "value": { "type": ["boolean", "null"] }
                  },
                  "required": ["name", "description", "value"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "name": { "const": "smokeFacilitiesComments" },
                    "description": { "const": "Comments on the smoking facilities." },
                    "value": { "type": ["string", "null"] }
                  },
                  "required": ["name", "description", "value"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "name": { "const": "smokeSignage" },
                    "description": { "const": "Is non-smoking signage visible?" },
                    "value": { "type": ["boolean", "null"] }
                  },
                  "required": ["name", "description", "value"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "name": { "const": "smokeSignageComments" },
                    "description": { "const": "Comments on the non-smoking signage." },
                    "value": { "type": ["string", "null"] }
                  },
                  "required": ["name", "description", "value"],
                  "additionalProperties": false
                }
              ]
            },
            "minItems": 4,
            "maxItems": 4
          }
      },
      "required": ["fields"],
      "additionalProperties": false
    }
  }
